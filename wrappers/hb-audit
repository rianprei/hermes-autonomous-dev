#!/bin/sh
# hb audit — mostra resumo da última sessão Hermes (arquivos, comandos,
# checkpoints, modelo, tempo). Consulta o state.db (SQLite/FTS5).
set -u
PY="$HOME/.hermes/hb_audit.py"
[ -f "$PY" ] || cat > "$PY" <<'PYEOF'
import os, sqlite3, json, sys, glob

home = os.path.expanduser("~/.hermes")
db = os.path.join(home, "state.db")
if not os.path.exists(db):
    print("[FAIL] state.db não encontrado em", db)
    sys.exit(1)

con = sqlite3.connect(db)
con.row_factory = sqlite3.Row
cur = con.cursor()

# descobre tabelas
cur.execute("SELECT name FROM sqlite_master WHERE type='table'")
tables = [r[0] for r in cur.fetchall()]
print("Tabelas:", ", ".join(tables))

def colsof(t):
    cur.execute(f"PRAGMA table_info({t})")
    return [r[1] for r in cur.fetchall()]

# tenta achar a tabela de sessões
sess_tbl = None
for t in tables:
    cols = colsof(t)
    if any(c in ("title","created_at","model","session_id","id") for c in cols) and ("messages" in cols or "transcript" in cols or "created_at" in cols):
        sess_tbl = t
        break
if not sess_tbl:
    sess_tbl = tables[0] if tables else None

print("\n=== ÚLTIMA SESSÃO ===")
if sess_tbl:
    cols = colsof(sess_tbl)
    order = "created_at" if "created_at" in cols else ("id" if "id" in cols else cols[0])
    q = f"SELECT * FROM {sess_tbl} ORDER BY {order} DESC LIMIT 1"
    cur.execute(q)
    row = cur.fetchone()
    if row:
        for c in cols:
            v = row[c]
            s = str(v)
            if len(s) > 200: s = s[:200] + "…"
            print(f"  {c}: {s}")
    else:
        print("  (sem sessões)")

# logs de checkpoint
cp_dir = os.path.join(home, "checkpoints")
if os.path.isdir(cp_dir):
    cps = glob.glob(os.path.join(cp_dir, "**", "*.json"), recursive=True)
    print(f"\n=== CHECKPOINTS ({len(cps)}) ===")
    for c in sorted(cps)[-5:]:
        print("  ", os.path.relpath(c, cp_dir))

# logs de gateway/erro
logs = os.path.join(home, "logs")
if os.path.isdir(logs):
    print("\n=== LOGS ===")
    for f in sorted(os.listdir(logs))[-5:]:
        print("  ", f)
con.close()
PYEOF
python3 "$PY" 2>&1
